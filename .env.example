# ------------------------------------------------------------
# Rail Clinic Inventory - Environment Template
# Copy this file to `.env.local` for local development.
# For Vercel deployment, add the same keys in Project Settings > Environment Variables.
# ------------------------------------------------------------

# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Rail Clinic Inventory
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Jakarta
NEXT_PUBLIC_IMAGE_PROVIDER=cloudinary
NEXT_PUBLIC_DEPLOY_ENV=local

# Security / Session
# Use a long random value in production.
SESSION_SECRET=replace-with-a-long-random-secret

# Neon Postgres
# Pooled connection string for app/runtime queries.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional direct/unpooled connection, useful for migrations.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional split Postgres variables if needed by tools/scripts.
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: use either CLOUDINARY_URL or the 3 vars above.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Upload conventions
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=rail-clinic-inventory
CLOUDINARY_SECURE_DELIVERY=true

# Vercel
# Optional for CLI/CI workflows. Not required for dashboard-based deploys.
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
VERCEL_TOKEN=

# Feature flags / app behavior
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_SHOW_DEMO_DATA=false
NEXT_PUBLIC_ENABLE_IMAGE_UPLOAD=true
NEXT_PUBLIC_ENABLE_HANDOVER_MODULE=true

# Notes:
# 1. Never expose DATABASE_URL, SESSION_SECRET, or CLOUDINARY_API_SECRET to the browser.
# 2. Only variables prefixed with NEXT_PUBLIC_ are exposed to client-side code.
# 3. Store image metadata (public_id, secure_url, folder) in Neon, not the raw files.
